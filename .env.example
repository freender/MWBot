# ── Telegram ──────────────────────────────────────────────
TOKEN=                          # Bot token from @BotFather
CHAT_ID=                        # Default chat ID for bot replies
NOTIFY_CHAT_ID=                 # (optional) Separate chat for maintenance notifications; defaults to CHAT_ID
OWNER=                          # Telegram user ID of the bot owner (integer)
TELEGRAM_AUTH_USERS=            # JSON array of authorized user IDs, e.g. [123,456]

# ── Uptime Kuma ───────────────────────────────────────────
KUMA_HOST=                      # Uptime Kuma base URL, e.g. https://kuma.example.com
KUMA_LOGIN=                     # Uptime Kuma username
KUMA_PASSWORD=                  # Uptime Kuma password
KUMA_MW_ID=                     # Maintenance window ID (integer)

# ── Cloudflare WAF ────────────────────────────────────────
WAF_TOKEN=                      # Cloudflare API bearer token
WAF_ZONE=                       # Zone ID
WAF_RULESET=                    # Ruleset ID
WAF_RULEID=                     # Rule ID
CDN_URL=                        # CDN hostname used in WAF expression
MW_BOT_ASN_DEFAULT=             # Default ASN for firewall rules

# ── Seerr ─────────────────────────────────────────────────
SEERR_BASE_URL=                 # Internal Seerr URL, e.g. http://seerr:5055
SEERR_PUBLIC_URL=               # (optional) Public Seerr URL for Telegram inline buttons; defaults to empty
SEERR_API_KEY=                  # Seerr API key
SEERR_ACCESS_ENV_ONLY=          # (optional) Set to true to skip Seerr auth sync and use TELEGRAM_AUTH_USERS/OWNER only
SEERR_ACCESS_TEST_USER_ID=      # (optional) Telegram user ID to override for auth testing
SEERR_ACCESS_TEST_MODE=         # (optional) normal|owner|authorized|unauthorized for SEERR_ACCESS_TEST_USER_ID

# ── Sonarr / Radarr ──────────────────────────────────────
SONARR_BASE_URL=                # Sonarr base URL, e.g. http://sonarr:8989
SONARR_API_KEY=                 # Sonarr API key
RADARR_BASE_URL=                # Radarr base URL, e.g. http://radarr:7878
RADARR_API_KEY=                 # Radarr API key

# ── 4K instances (optional, fall back to standard) ───────
SONARR4K_BASE_URL=              # (optional) 4K Sonarr base URL; defaults to SONARR_BASE_URL
SONARR4K_API_KEY=               # (optional) 4K Sonarr API key; defaults to SONARR_API_KEY
RADARR4K_BASE_URL=              # (optional) 4K Radarr base URL; defaults to RADARR_BASE_URL
RADARR4K_API_KEY=               # (optional) 4K Radarr API key; defaults to RADARR_API_KEY

# ── General ───────────────────────────────────────────────
TZ=UTC                          # Timezone, e.g. America/New_York
